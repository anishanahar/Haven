# Copy to .env for local development.

# Postgres connection used by Prisma.
DATABASE_URL="postgresql://localhost:5432/nest_dev?schema=public"

# Redis connection used for sessions, rate limiting, and the indexer's
# pub/sub bridge to WebSocket clients.
REDIS_URL="redis://localhost:6379"

# HTTP server
PORT=4000
HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="info"
CORS_ORIGIN="http://localhost:3000"

# Auth
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
SEP10_CHALLENGE_TTL_SECONDS=300

# Stellar / Soroban
STELLAR_NETWORK="TESTNET"
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
HORIZON_URL="https://horizon-testnet.stellar.org"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Server's own signing identity, used only to sign SEP-10 challenge
# transactions (the "server account" role) — never used to sign user funds
# transactions. Generate a fresh Stellar keypair for this; it holds no funds.
SEP10_SERVER_SECRET=""
HOME_DOMAIN="localhost:3000"
WEB_AUTH_DOMAIN="localhost:4000"

# Deployed contract addresses (see docs/deployment.md)
GOAL_FACTORY_CONTRACT_ID=""
TREASURY_CONTRACT_ID=""
MOCK_STRATEGY_CONTRACT_ID=""
USDC_TOKEN_CONTRACT_ID=""

# Indexer
INDEXER_POLL_INTERVAL_MS=3000
INDEXER_START_LEDGER=0
